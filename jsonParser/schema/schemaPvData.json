{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "version": {
      "type": "number"
    },
    "pvData": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "endpoint": {
            "type": "string"
          },
          "value": {
            "oneOf": [
              {
                "type": "integer",
                "description": "Integer value"
              },
              {
                "type": "number",
                "description": "Floating point value",
                "not": {
                  "type": "integer"
                }
              }
            ]
          }
        },
        "required": [
          "endpoint",
          "value"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "pvData",
    "version"
  ],
  "additionalProperties": false
}
